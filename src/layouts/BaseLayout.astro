---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '@/styles/global.css';

const { title, description, image } = Astro.props;
const defaultImage = "https://thefrenchfins.netlify.app/images/hard-rock-stadium.png";
const currentPath = Astro.url.pathname;
const goatDomain = "thefrenchfins"; 

let views = 0;

try {
  const response = await fetch(`https://${goatDomain}.goatcounter.com/counter/${encodeURIComponent(currentPath)}.json`);
  if (response.ok) {
    const data = await response.json();
    views = parseInt(data.count.replace(/,/g, '')) || 0;
  }
} catch (e) {
  console.log("⏳ En attente des données GoatCounter...");
}
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="google-site-verification" content="google-site-verification=TuYlP1QL8Q5qvSMxLBJIHfGenQwwjXcF-vHDlb-4V6o" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
    
    <title>{title} | The French Fins</title>
    <meta name="description" content={description || "L'actualité des Miami Dolphins en français."} />

    {/* Métadonnées OG/Twitter partagées */}
    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image || defaultImage} />
    <meta name="twitter:card" content="summary_large_image" />

    {/* NOTE : On ne met PLUS le script Google Analytics ici en dur. 
        Il est géré par le script de consentement en bas de page.
    */}
  </head>

  <body class="bg-gray-50 text-gray-900">
    <Navbar /> 
    <main class="max-w-360 mx-auto py-10 px-4"> 
      {views > 0 && (
        <div class="flex items-center gap-2 text-[#008E97] font-bold mb-6 border-b border-gray-200 pb-4">
          <span class="text-xl">🐬</span>
          <span class="uppercase tracking-wide text-sm">
            {views} {views > 1 ? 'fans ont lu cet article' : 'fan a lu cet article'}
          </span>
        </div>
      )}
      <slot />
    </main>
    <Footer />

    {/* Script Netlify Identity */}
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      const identity = window.netlifyIdentity;
      if (identity) {
        identity.on("init", user => {
          if (!user) {
            identity.on("login", () => { document.location.href = "/admin/"; });
          }
        });
      }
    </script>

    {/* LOGIQUE ANALYTICS & CONSENTEMENT */}
    <script is:inline>
      const storageKey = 'the-french-fins-consent';
      const consent = localStorage.getItem(storageKey);
      const GA_ID = 'G-4Z0N5P5QLD';

      // 1. Si consenti, on charge Google Analytics
      if (consent === 'accepted') {
        const script = document.createElement('script');
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GA_ID);

        // Tracking des clics sur les articles (seulement si accepté)
        document.addEventListener('click', (e) => {
          const link = e.target.closest('a');
          if (link && link.href.includes('/blog/')) {
            gtag('event', 'select_content', {
              content_type: 'article',
              item_id: link.href,
              item_name: link.innerText.trim()
            });
          }
        });
      }

      // 2. Gestion du bandeau de cookies
      const banner = document.getElementById('cookie-banner');
      if (!consent) {
        setTimeout(() => {
          banner.classList.remove('hidden');
          banner.classList.remove('translate-y-10');
        }, 1000);
      }

      document.getElementById('accept-cookies').addEventListener('click', () => {
        localStorage.setItem(storageKey, 'accepted');
        banner.classList.add('hidden');
        window.location.reload(); // Recharge pour activer GA
      });

      document.getElementById('refuse-cookies').addEventListener('click', () => {
        localStorage.setItem(storageKey, 'refused');
        banner.classList.add('hidden');
      });
    </script>

    {/* BANDEAU HTML */}
    <div id="cookie-banner" class="fixed bottom-6 left-6 right-6 md:left-auto md:max-w-md bg-white p-6 shadow-2xl rounded-2xl border-t-4 border-[#F58220] hidden z-[100] transform transition-all duration-500 translate-y-10">
      <div class="flex items-start gap-4">
        <div class="text-3xl">🐬</div>
        <div>
          <h3 class="font-[Oswald] font-bold text-gray-900 uppercase italic leading-none mb-2">Playbook des Cookies</h3>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            On utilise des cookies pour analyser notre attaque. Promis, pas de cookies de chez les Patriots ici !
          </p>
          <div class="flex flex-wrap gap-3">
            <button id="accept-cookies" class="bg-[#008E97] text-white px-5 py-2 rounded-lg text-xs font-black uppercase tracking-widest hover:bg-[#005f66] transition-colors">C'est validé !</button>
            <button id="refuse-cookies" class="text-gray-400 text-xs font-bold hover:text-miami-orange transition-colors">Non merci</button>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>