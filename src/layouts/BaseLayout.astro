---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '@/styles/global.css';

const { title, description, image } = Astro.props;
const defaultImage = "https://thefrenchfins.netlify.app/images/hard-rock-stadium.png";
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="google-site-verification" content="google-site-verification=TuYlP1QL8Q5qvSMxLBJIHfGenQwwjXcF-vHDlb-4V6o" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
    
    <title>{title} | The French Fins</title>
    <meta name="description" content={description || "L'actualité des Miami Dolphins en français."} />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image || defaultImage} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>

  <body class="bg-gray-50 text-gray-900">
    <Navbar /> 
    <main class="max-w-360 mx-auto py-10 px-4"> 
      <slot />
    </main>
    <Footer />

    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

    <script is:inline>
      window.CUSDIS_LOCALE = {
        post: 'Publier',
        loading: 'Chargement...',
        placeholder: 'Écrire un commentaire...',
        nickname: 'Pseudo',
        mail: 'E-mail (optionnel)',
        reply: 'Répondre',
        error: 'Une erreur est survenue'
      };

      document.addEventListener('DOMContentLoaded', () => {
        const storageKey = 'the-french-fins-consent';
        const consent = localStorage.getItem(storageKey);
        const GA_ID = 'G-4Z0N5P5QLD';

        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('accept-cookies');
        const refuseBtn = document.getElementById('refuse-cookies');

        if (banner && !consent) {
          setTimeout(() => {
            banner.classList.remove('hidden');
            setTimeout(() => banner.classList.remove('translate-y-10'), 100);
          }, 1000);
        }

        if (acceptBtn) {
          acceptBtn.addEventListener('click', () => {
            localStorage.setItem(storageKey, 'accepted');
            banner?.classList.add('hidden');
            window.location.reload();
          });
        }

        if (refuseBtn) {
          refuseBtn.addEventListener('click', () => {
            localStorage.setItem(storageKey, 'refused');
            banner?.classList.add('hidden');
          });
        }

        if (consent === 'accepted') {
          const script = document.createElement('script');
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
          document.head.appendChild(script);

          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
        }
      });
    </script>

    <div id="cookie-banner" class="fixed bottom-6 left-6 right-6 md:left-auto md:max-w-md bg-white p-6 shadow-2xl rounded-2xl border-t-4 border-[#F58220] hidden z-[100] transform transition-all duration-500 translate-y-10">
      <div class="flex items-start gap-4">
        <div class="text-3xl">🐬</div>
        <div>
          <h3 class="font-[Oswald] font-bold text-gray-900 uppercase italic leading-none mb-2">Playbook des Cookies</h3>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">On utilise des cookies pour analyser notre attaque. Pas de cookies de chez les Patriots ici !</p>
          <div class="flex flex-wrap gap-3">
            <button id="accept-cookies" class="bg-[#008E97] text-white px-5 py-2 rounded-lg text-xs font-black uppercase tracking-widest hover:bg-[#005f66] transition-colors shadow-lg shadow-miami-aqua/20">C'est validé !</button>
            <button id="refuse-cookies" class="text-gray-400 text-xs font-bold hover:text-miami-orange transition-colors">Non merci</button>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>