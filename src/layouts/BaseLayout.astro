---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '@/styles/global.css';

// 1. Récupération des Props
const { title, description, image } = Astro.props;

// 2. Définition des variables
const defaultImage = "https://thefrenchfins.netlify.app/images/hard-rock-stadium.png";
const currentPath = Astro.url.pathname;
const goatDomain = "thefrenchfins"; // Vérifie que c'est bien le nom choisi sur GoatCounter

let views = 0;

// 3. Récupération des vues via l'API publique de GoatCounter
try {
  // On appelle l'API de compteur pour le chemin actuel
  const response = await fetch(`https://${goatDomain}.goatcounter.com/counter/${encodeURIComponent(currentPath)}.json`);
  if (response.ok) {
    const data = await response.json();
    // On nettoie le chiffre (GoatCounter peut renvoyer "1,234" sous forme de string)
    views = parseInt(data.count.replace(/,/g, '')) || 0;
  }
} catch (e) {
  // Au premier build, il est normal d'avoir 0 si personne n'a encore visité la page
  console.log("⏳ En attente des premières données GoatCounter pour cette page...");
}
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="google-site-verification" content="google-site-verification=TuYlP1QL8Q5qvSMxLBJIHfGenQwwjXcF-vHDlb-4V6o" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
    
    <title>{title} | The French Fins</title>
    <meta name="description" content={description || "L'actualité des Miami Dolphins en français."} />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image || defaultImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image || defaultImage} />

    <script data-goatcounter={`https://${goatDomain}.goatcounter.com/count`}
        async src="//gc.zgo.at/count.js">
    </script>

  </head>
  <body class="bg-gray-50 text-gray-900">
    <Navbar /> 
    <main class="max-w-360 mx-auto py-10 px-4"> 
      
      {/* Affichage du compteur dès qu'il y a au moins une vue */}
      {views > 0 && (
        <div class="flex items-center gap-2 text-[#008E97] font-bold mb-6 border-b border-gray-200 pb-4">
          <span class="text-xl">🐬</span>
          <span class="uppercase tracking-wide text-sm">
            {views} {views > 1 ? 'fans ont lu cet article' : 'fan a lu cet article'}
          </span>
        </div>
      )}

      <slot />
    </main>
    <Footer />

    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

    <script is:inline>
      const identity = window.netlifyIdentity;
      if (identity) {
        identity.on("init", user => {
          if (!user) {
            identity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>