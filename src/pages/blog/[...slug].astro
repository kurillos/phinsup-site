---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const siteUrl = "https://thefrenchfins.netlify.app";
const ogImage = entry.data.heroImage 
  ? (entry.data.heroImage.startsWith('http') ? entry.data.heroImage : siteUrl + entry.data.heroImage)
  : siteUrl + "/images/hard-rock-stadium.png";

const goatDomain = "thefrenchfins";
const currentPath = Astro.url.pathname;
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={ogImage}>
  <article class="max-w-4xl mx-auto py-10 px-4"> 
    
    {entry.data.heroImage && (
      <img src={entry.data.heroImage} alt={entry.data.title} class="w-full h-auto max-h-125 object-contain bg-gray-50 rounded-xl mb-8 shadow-lg border-b-8 border-miami-orange" />
    )}

    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-2">
        <span class="bg-miami-orange text-white px-3 py-1 rounded text-xs font-bold uppercase italic">{entry.data.category}</span>
        {entry.data.tags && entry.data.tags.map(tag => <span class="text-gray-400 text-xs italic">#{tag}</span>)}
      </div>
      
      <h1 class="text-4xl md:text-6xl font-extrabold text-miami-aqua mt-2 font-[Oswald] italic uppercase leading-tight">{entry.data.title}</h1>

      <div class="flex flex-col md:flex-row md:items-center justify-between mt-6 border-l-4 border-miami-aqua pl-4 gap-4">
        <p class="text-gray-400 italic">Publié le {entry.data.pubDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
        
        <div id="view-counter" class="flex items-center gap-2 text-[#008E97] font-bold bg-miami-aqua/5 px-3 py-1 rounded-full w-fit border border-miami-aqua/10">
          <span>🐬</span>
          <span id="view-count-text" class="text-xs uppercase tracking-wider italic">Analyse...</span>
        </div>
      </div>
    </header>

    <div class="article-body max-w-none">
      <Content />
    </div>

    <section class="mt-16 pt-10 border-t-4 border-[#008E97] bg-gray-50 p-6 rounded-xl shadow-inner overflow-hidden">
      
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <h2 class="text-3xl font-bold font-[Oswald] italic uppercase text-gray-900 tracking-tighter">
          Le vestiaire <span class="text-[#F58220]">(Commentaires)</span>
        </h2>
        
        <button id="btn-open-comment" class="bg-[#008E97] text-white px-6 py-2 rounded-full font-bold uppercase italic text-sm hover:bg-[#F58220] transition-all shadow-lg active:scale-95 flex items-center gap-2">
          <span id="btn-icon">💬</span> <span id="btn-text">Commenter</span>
        </button>
      </div>

      <div id="write-zone" class="hidden opacity-0 translate-y-4 transition-all duration-300 mb-10 p-6 bg-white rounded-xl border-2 border-miami-aqua shadow-xl">
          <div class="flex justify-between items-center mb-4">
              <p class="font-bold text-[#008E97] uppercase text-sm italic">Nouvelle réaction :</p>
              <button id="btn-close-write" class="text-gray-400 hover:text-miami-orange text-xl font-bold">×</button>
          </div>
          <div id="cusdis_thread" 
               data-host="https://cusdis.com" 
               data-app-id="b8f71c42-b009-4069-83ac-1c696a10f3ff" 
               data-page-id={entry.slug} 
               data-page-url={Astro.url.href} 
               data-page-title={entry.data.title}>
          </div>
      </div>

      <div id="display-zone" class="w-full">
          </div>

      <script async defer src="https://cusdis.com/js/cusdis.es.js"></script>
    </section>

    <footer class="mt-12 pt-8 border-t border-gray-200">
      <a href="/" class="inline-flex items-center gap-2 text-miami-aqua hover:text-miami-orange font-bold transition-all hover:-translate-x-1">← Retour aux articles</a>
    </footer>
  </article>

  <script is:inline define:vars={{ goatDomain, currentPath }}>
    // 1. Compteur de vues
    async function updateViews() {
      const counterText = document.getElementById('view-count-text');
      if (!counterText) return;
      try {
        const cleanPath = currentPath.replace(/\/$/, "") || "/";
        const statsUrl = `https://${goatDomain}.goatcounter.com/counter/${encodeURIComponent(cleanPath)}.json?t=${Date.now()}`;
        const response = await fetch(statsUrl);
        const data = await response.json();
        if (data && data.count) {
          const views = parseInt(data.count.replace(/,/g, '')) || 0;
          counterText.innerText = `${views} ${views > 1 ? 'lecteurs' : 'lecteur'}`;
        } else {
          counterText.innerText = "Fins Up!";
        }
      } catch (e) { counterText.innerText = "Fins Up!"; }
    }

    // 2. Gestion de la zone de rédaction "Modale"
    function setupCommentUI() {
        const btnOpen = document.getElementById('btn-open-comment');
        const btnClose = document.getElementById('btn-close-write');
        const writeZone = document.getElementById('write-zone');

        btnOpen?.addEventListener('click', () => {
            writeZone.classList.remove('hidden');
            setTimeout(() => {
                writeZone.classList.add('opacity-100', 'translate-y-0');
            }, 10);
            btnOpen.classList.add('hidden');
        });

        btnClose?.addEventListener('click', () => {
            writeZone.classList.remove('opacity-100', 'translate-y-0');
            setTimeout(() => {
                writeZone.classList.add('hidden');
                btnOpen.classList.remove('hidden');
            }, 300);
        });
    }

    // 3. Auto-resize de l'iframe
    window.addEventListener('message', (e) => {
      try {
        const data = JSON.parse(e.data);
        if (data.target === 'cusdis' && data.type === 'resize') {
          const iframe = document.querySelector('#cusdis_thread iframe');
          if (iframe) {
            iframe.style.height = data.data + 'px';
          }
        }
      } catch (err) {}
    });

    updateViews();
    setupCommentUI();
  </script>
</BaseLayout>

<style is:global>
  .article-body h3 { margin-top: 3.5rem !important; margin-bottom: 1.5rem !important; font-family: 'Oswald', sans-serif !important; font-weight: 700 !important; font-style: italic !important; text-transform: uppercase !important; color: #008e97 !important; font-size: 1.75rem !important; }
  .article-body p { margin-bottom: 1.5rem !important; line-height: 1.8 !important; font-size: 1.05rem !important; color: #374151 !important; }
  .article-body strong { color: #f58220 !important; font-weight: 800 !important; }
  
  /* Masquer le formulaire par défaut de Cusdis pour ne garder que la liste */
  /* On ne garde le formulaire que lorsqu'il est dans la "write-zone" */
  #display-zone #cusdis_thread form {
      display: none !important;
  }

  #cusdis_thread iframe {
    width: 100% !important;
    border: none !important;
    overflow: hidden !important;
  }
</style>