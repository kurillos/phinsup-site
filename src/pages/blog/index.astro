---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import episodesData from '../../data/podcasts.json';

// 1. Sécurisation Podcast (on renomme pour éviter les conflits)
const lastEpisode = (episodesData && Array.isArray(episodesData) && episodesData.length > 0) 
    ? episodesData[0] 
    : null;

// 2. Récupération articles avec filtrage immédiat des objets nuls
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => {
    // On ne garde que les articles qui :
    // 1. Ne sont pas des brouillons
    // 2. ONT une date de publication passée ou égale à MAINTENANT
    return !post.data.isDraft && post.data.pubDate <= new Date();
  })
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Accueil - The Phin Side">
    <main class="max-w-7xl mx-auto py-10 px-4">
        
        <div class="flex items-center space-x-4 mb-10 border-l-8 border-miami-orange pl-6">
            <h1 class="text-4xl font-bold text-gray-900 font-[Oswald] italic uppercase tracking-tighter">
                L'actualité des <span class="text-miami-aqua">Phins</span>
            </h1>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            
            <div class="lg:col-span-2">
                <div class="grid gap-8 md:grid-cols-2">
                    {posts.map((post) => {
                        // On extrait proprement avec des fallbacks
                        const data = post.data || {};
                        const title = data.title || "Titre non disponible";
                        const author = data.author || "The Phin Side Staff";
                        const dateStr = data.pubDate ? new Date(data.pubDate).toLocaleDateString('fr-FR') : "";

                        return (
                            <article class="group relative bg-white rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 border border-gray-100 flex flex-col h-full">
                                <div class="relative h-52 overflow-hidden bg-gray-200">
                                    <img 
                                        src={data.heroImage || "/images/hard-rock-stadium.png"} 
                                        alt={title} 
                                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                    />
                                </div>

                                <div class="p-6 grow flex flex-col">
                                    <div class="flex items-center justify-between mb-3">
                                        <span class="bg-miami-aqua/10 text-miami-aqua text-[10px] font-black uppercase px-2 py-1 rounded-md">
                                            {data.category || "Actu"}
                                        </span>
                                        <span class="text-gray-400 text-xs font-medium">{dateStr}</span>
                                    </div>

                                    <h2 class="text-2xl font-bold text-gray-900 font-[Oswald] leading-tight mb-3">
                                        <a href={`/blog/${post.slug}/`}>{title}</a>
                                    </h2>

                                    <p class="text-gray-600 text-sm line-clamp-3 mb-4">{data.description || ""}</p>
                                    
                                    <div class="mt-auto pt-4 border-t border-gray-50 flex items-center text-miami-orange font-bold text-xs uppercase italic">
                                        <span>Par Author</span>
                                    </div>
                                </div>
                            </article>
                        );
                    })}
                </div>
            </div>

            <aside class="space-y-8">
                {/* BLINDAGE TOTAL DU PODCAST */}
                {lastEpisode && lastEpisode.title ? (
                    <div class="bg-gray-900 rounded-2xl overflow-hidden shadow-xl border-b-8 border-miami-orange">
                        <div class="p-6">
                            <div class="flex items-center justify-between mb-4">
                                <span class="bg-miami-orange text-white text-[10px] font-black uppercase px-2 py-0.5 rounded">Dernier Épisode</span>
                                <span class="text-gray-400 text-[10px] font-bold">{lastEpisode.date || ""}</span>
                            </div>
                            
                            <h3 class="text-white font-[Oswald] italic font-bold text-xl mb-4">
                                {lastEpisode.title}
                            </h3>

                            <iframe 
                                style="border-radius:12px; border: none;" 
                                src={`https://open.spotify.com/embed/episode/${lastEpisode.spotifyId || ""}`} 
                                width="100%" 
                                height="152" 
                                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
                                loading="lazy">
                            </iframe>
                        </div>
                    </div>
                ) : null}

                <div class="bg-white p-6 rounded-2xl shadow-md border border-gray-100">
                    <h3 class="font-[Oswald] font-bold italic uppercase text-gray-900 mb-4 border-b-2 border-miami-aqua pb-2">Flux Twitter</h3>
                    <div class="max-h-150 overflow-y-auto">
                        <a class="twitter-timeline" href="https://twitter.com/MiamiDolphins">Tweets by MiamiDolphins</a> 
                    </div>
                </div>
            </aside>
        </div>
    </main>
</BaseLayout>