---
import Layout from '../layouts/BaseLayout.astro';
// Assure-toi que le fichier existe bien dans src/data/roster.json
import players from '../data/roster.json';
---

<Layout title="Roster 2026 - The Phin Side">
  <main class="max-w-7xl mx-auto py-12 px-6">
    
    <div class="mb-12">
      <h1 class="text-5xl font-[Oswald] font-black italic uppercase text-miami-aqua tracking-tighter">
        Effectif <span class="text-miami-orange">2026</span>
      </h1>
      
      <div class="mb-12">
  <h1 class="text-5xl font-[Oswald] font-black italic uppercase text-miami-aqua tracking-tighter">
    Effectif <span class="text-miami-orange">2026</span>
  </h1>
  
  <div class="flex flex-wrap gap-3 mt-8">
    <button class="filter-btn active" data-filter="all">Tous</button>
    <button class="filter-btn" data-filter="offense">Offensif</button>
    <button class="filter-btn" data-filter="defense">Défensif</button>
    <button class="filter-btn" data-filter="special">Spécial</button>
  </div>

  <div class="flex flex-wrap gap-2 mt-4 border-l-2 border-gray-200 pl-4">
    <button class="sub-filter-btn" data-filter="passing">Passing</button>
    <button class="sub-filter-btn" data-filter="rushing">Rushing</button>
    <button class="sub-filter-btn" data-filter="receiving">Receiving</button>
    <button class="sub-filter-btn" data-filter="line">Line</button>
    <button class="sub-filter-btn" data-filter="secondary">Secondary</button>
  </div>
</div>

<div class="player-card ..." data-unit={player.unit} data-subunit={player.subUnit}>
   ...
</div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10" id="roster-grid">
      {players.map((player) => {
        // Logique de couleur dynamique par unité
        const isOffense = player.unit === 'offense';
        const isDefense = player.unit === 'defense';
        
        const themeColor = isOffense ? 'border-miami-aqua' : (isDefense ? 'border-miami-orange' : 'border-gray-400');
        const themeBg = isOffense ? 'bg-miami-aqua' : (isDefense ? 'bg-miami-orange' : 'bg-gray-400');
        const themeText = isOffense ? 'text-miami-aqua' : (isDefense ? 'text-miami-orange' : 'text-gray-400');

        return (
          <div class="player-card perspective-1000 h-[480px]" data-unit={player.unit}>
            <div class="flip-card-inner relative w-full h-full duration-700 preserve-3d cursor-pointer">
              
              <div class={`absolute inset-0 backface-hidden rounded-2xl shadow-xl bg-white border-b-8 ${themeColor} overflow-hidden`}>
                <div class="relative h-3/4 bg-gray-100 flex items-center justify-center overflow-hidden">
                  <img 
                    src={player.image} 
                    alt={player.name} 
                    class="w-full h-full object-contain sm:object-cover grayscale hover:grayscale-0 transition-all duration-500" 
                  />
                  <div class={`absolute top-4 left-4 ${themeBg} text-white font-[Oswald] font-bold text-3xl px-3 py-1 rounded shadow-lg italic`}>
                    #{player.number}
                  </div>
                </div>
                <div class="p-5">
                  <h3 class="font-[Oswald] font-bold text-2xl uppercase italic text-gray-900 leading-tight">
                    {player.name}
                  </h3>
                  <p class={`${themeText} font-black tracking-widest text-xs uppercase mt-1`}>
                    {player.position} | {player.college}
                  </p>
                </div>
              </div>

              <div class={`absolute inset-0 backface-hidden rotate-y-180 rounded-2xl shadow-2xl ${themeBg} text-white p-6 flex flex-col justify-between border-4 border-white/20`}>
                <div>
                  <div class="flex justify-between items-start border-b border-white/20 pb-3 mb-4">
                    <h3 class="font-[Oswald] text-3xl uppercase italic leading-none">{player.name}</h3>
                    <span class="font-[Oswald] text-2xl opacity-50">#{player.number}</span>
                  </div>
                  
                  <div class="grid grid-cols-3 gap-2 text-center mb-6">
                    <div class="bg-white/10 p-2 rounded">
                      <p class="text-[10px] uppercase opacity-70 font-bold">{player.stats.label}</p>
                      <p class="text-xl font-black">{player.stats.val1}</p>
                    </div>
                    <div class="bg-white/10 p-2 rounded border-x border-white/10">
                      <p class="text-[10px] uppercase opacity-70 font-bold">Yards</p>
                      <p class="text-xl font-black">{player.stats.val2}</p>
                    </div>
                    <div class="bg-white/10 p-2 rounded">
                      <p class="text-[10px] uppercase opacity-70 font-bold">TDs</p>
                      <p class={`text-xl font-black ${Number(player.stats.val3) >= 10 ? 'text-yellow-300 animate-pulse' : 'text-white'}`}>
                        {player.stats.val3}
                      </p>
                    </div>
                  </div>

                  <div class="mb-4">
                    <p class="text-[10px] uppercase font-black text-white/60 tracking-widest">Célébration</p>
                    <p class="font-[Oswald] italic text-lg text-white">{player.celebration}</p>
                  </div>
                </div>

                <div class="text-sm leading-snug border-t border-white/20 pt-4 italic opacity-90">
                  "{player.bio}"
                </div>
              </div>

            </div>
          </div>
        )
      })}
    </div>
  </main>
</Layout>

<style>
  .filter-btn, .sub-filter-btn {
    font-family: 'Oswald', sans-serif;
    text-transform: uppercase;
    font-style: italic;
    font-weight: 700;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  /* Style boutons principaux */
  .filter-btn {
    padding: 0.5rem 1.5rem;
    border-radius: 9999px;
    border: 2px solid #008E97;
    color: #008E97;
    background: transparent;
  }

  .filter-btn.active, .filter-btn:hover {
    background: #008E97;
    color: white;
  }

  /* Style sous-boutons (plus petits) */
  .sub-filter-btn {
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    font-size: 0.75rem;
    background: white;
  }

  .sub-filter-btn.active, .sub-filter-btn:hover {
    border-color: #F26722;
    color: #F26722;
  }

  .player-card.hidden-filter {
    display: none;
  }
</style>

<script>
  const initRoster = () => {
    const cards = document.querySelectorAll('.flip-card-inner');
    const allBtns = document.querySelectorAll('.filter-btn, .sub-filter-btn');
    const playerCards = document.querySelectorAll('.player-card');

    // 1. Flip
    cards.forEach(card => {
      card.onclick = () => card.classList.toggle('is-flipped');
    });

    // 2. Filtres
    allBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Gérer le style actif
        allBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.getAttribute('data-filter');

        playerCards.forEach(card => {
          const unit = card.getAttribute('data-unit');
          const subUnit = card.getAttribute('data-subunit');

          // Si "Tous" ou si ça match l'unité OU la sous-unité
          if (filter === 'all' || unit === filter || subUnit === filter) {
            card.classList.remove('hidden-filter');
          } else {
            card.classList.add('hidden-filter');
          }
        });
      });
    });
  };

  initRoster();
  document.addEventListener('astro:after-swap', initRoster);
</script>